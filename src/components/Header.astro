---
// Shared site header + mobile off-canvas nav.
// `currentPath` marks the active nav item (e.g. "/contact/").
const { currentPath = "" } = Astro.props;

const navItems = [
  { href: "/our-approach/", label: "Our Approach" },
  { href: "/tax-accounting-services/", label: "Services" },
  { href: "/contact/", label: "Contact" },
];

const phoneIcon =
  "M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z";
---
<header class="site-header">
  <div class="container">
    <a href="/" class="site-logo">
      <img src="/assets/img/LOGO_Proactive_v2-WHT_1000x400.svg" alt="Proactive Accounting &amp; Tax" width="180" height="72">
    </a>
    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={item.href === currentPath ? "page" : undefined}>{item.label}</a>
          </li>
        ))}
      </ul>
      <a href="tel:+17602050625" class="header-phone">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={phoneIcon}/></svg>
        (760) 205-0625
      </a>
    </nav>
    <a href="/contact/" class="btn header-cta">Start Today</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="offcanvas-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="offcanvas-overlay"></div>
<aside class="offcanvas" id="offcanvas-nav" role="dialog" aria-modal="true" aria-label="Menu">
  <button class="offcanvas-close" aria-label="Close menu">&times;</button>
  <nav aria-label="Mobile">
    {navItems.map((item) => (
      <a href={item.href} aria-current={item.href === currentPath ? "page" : undefined}>{item.label}</a>
    ))}
  </nav>
  <a href="tel:+17602050625" class="offcanvas-phone">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d={phoneIcon}/></svg>
    (760) 205-0625
  </a>
  <div><a href="/contact/" class="btn btn--solid">Start Today</a></div>
</aside>
