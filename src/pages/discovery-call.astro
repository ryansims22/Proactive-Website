---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Discovery Call - Proactive Accounting & Tax"
  description="Schedule your free tax discovery call with Proactive Accounting & Tax — a San Diego area CPA who plans ahead with you, not just at tax time."
  path="/discovery-call/"
  ogDescription="Schedule your free tax discovery call."
  ogImage="https://proactive-at.com/assets/img/BACK_Header_Office_1800x942.webp"
>
  <!-- ======================= Page hero ======================= -->
  <section class="page-hero page-hero--light">
    <div class="container">
      <h1>Discovery Call</h1>
    </div>
  </section>

  <!-- ======================= Schedule ======================= -->
  <section class="discovery">
    <div class="container">
      <h2 class="section-heading">Schedule your free tax discovery call</h2>
      <div class="rich-text">
        <p>Tell us a little about your business and where taxes feel stressful today. We&rsquo;ll set up a free, no-pressure call to see if we&rsquo;re a good fit &mdash; and you&rsquo;ll leave with at least one useful next step either way.</p>
      </div>
      <div class="discovery-actions">
        <a href="/contact/" class="btn btn--solid">Request Your Discovery Call</a>
        <a href="tel:+17602050625" class="contact-phone">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/></svg>
          or call (760) 205-0625
        </a>
        <a href="mailto:ryan@proactive-at.com" class="contact-email">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm8 7.9L4.5 6.6v10.8h15V6.6L12 11.9zm0-2.3L18.8 6H5.2L12 9.6z"/></svg>
          ryan@proactive-at.com
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
