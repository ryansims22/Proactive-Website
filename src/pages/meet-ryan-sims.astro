---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  url: "https://proactive-at.com/meet-ryan-sims/",
  mainEntity: {
    "@type": "Person",
    "@id": "https://proactive-at.com/meet-ryan-sims/#ryan-sims",
    name: "Ryan D. Sims",
    honorificSuffix: "CPA, EA, MBA",
    jobTitle: "Certified Public Accountant",
    description:
      "San Diego area CPA, IRS Enrolled Agent, and small business owner providing proactive tax planning, tax preparation, and business advisory. Background as a tax advisor, auditor, and bank examiner; military veteran.",
    image: "https://proactive-at.com/assets/img/IMG_About-Ryan_1200x1500.webp",
    url: "https://proactive-at.com/meet-ryan-sims/",
    telephone: "+1-760-205-0625",
    knowsAbout: [
      "Tax planning",
      "Tax preparation",
      "Bookkeeping",
      "Business entity structuring",
      "Small business accounting",
    ],
    hasCredential: [
      { "@type": "EducationalOccupationalCredential", credentialCategory: "license", name: "Certified Public Accountant (California)" },
      { "@type": "EducationalOccupationalCredential", credentialCategory: "license", name: "IRS Enrolled Agent" },
      { "@type": "EducationalOccupationalCredential", credentialCategory: "degree", name: "Master of Business Administration (MBA)" },
    ],
    worksFor: {
      "@type": "AccountingService",
      "@id": "https://proactive-at.com/#business",
      name: "Proactive Accounting & Tax",
      url: "https://proactive-at.com/",
    },
  },
};
---
<BaseLayout
  title="Meet Ryan Sims - Proactive Accounting & Tax"
  description="Meet Ryan D. Sims, CPA, EA, MBA — a San Diego area CPA, IRS Enrolled Agent, and small business owner who believes tax and accounting should feel clear, calm, and handled."
  path="/meet-ryan-sims/"
  ogDescription="Your proactive accounting & tax partner in Metro San Diego."
  ogImage="https://proactive-at.com/assets/img/IMG_About-Ryan_1200x1500.webp"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- ======================= Page hero ======================= -->
  <section class="page-hero">
    <div class="container">
      <h1>Meet Ryan Sims</h1>
    </div>
  </section>

  <!-- ======================= Intro ======================= -->
  <section class="split split--tight">
    <div class="container">
      <div class="split-col">
        <p class="eyebrow">Ryan D. Sims, CPA, EA, MBA</p>
        <h2>Your proactive accounting &amp; tax partner in Metro San Diego</h2>
        <div class="rich-text">
          <p>I&rsquo;m Ryan Sims &mdash; a San Diego area CPA, Enrolled Agent, and small business owner who believes tax and accounting should feel clear, calm, and handled &mdash; not stressful or confusing.</p>
          <p>I work with individuals and business owners who want a tax professional that shows up, explains things in plain English, and helps them plan ahead &mdash; not just react at tax time.</p>
        </div>
      </div>
      <div class="split-col split-media">
        <img src="/assets/img/IMG_About-Ryan_1200x1500.webp" alt="Ryan Sims, CPA and Enrolled Agent" width="600" height="750" loading="lazy">
      </div>
    </div>
  </section>

  <!-- ======================= Credentials ======================= -->
  <section class="center-section linetop pattern-left pattern-left--wide">
    <div class="container">
      <h2 class="section-heading">A different kind of CPA relationship</h2>
      <div class="rich-text">
        <p>I&rsquo;m licensed as a Certified Public Accountant in California and an Enrolled Agent with the IRS, which means I&rsquo;m authorized to represent clients at every level and handle everything from straightforward individual returns to complex business tax situations.</p>
        <p>But credentials alone don&rsquo;t build trust.</p>
        <p>What clients value most is knowing:</p>
        <ul>
          <li>Their questions will be answered</li>
          <li>Their situation won&rsquo;t be judged</li>
          <li>Their taxes won&rsquo;t be handled at the last minute</li>
          <li>Their CPA actually understands what it&rsquo;s like to run a business</li>
        </ul>
        <p>That&rsquo;s the relationship I aim to provide.</p>
      </div>
    </div>
  </section>

  <!-- ======================= Experience ======================= -->
  <section class="split split--inner pattern-left pattern-left--wide">
    <div class="container">
      <div class="split-col">
        <h2>Experience that translates into better guidance</h2>
        <div class="rich-text">
          <p>Before founding Proactive Accounting &amp; Tax, my background included work as a tax advisor, auditor, bank examiner, and business professional across multiple industries &mdash; as well as service as a military veteran.</p>
          <p>That experience shaped how I work today.</p>
          <p>I don&rsquo;t just look at forms.<br>I look at systems, timing, structure, and decisions &mdash; because those are the things that actually impact your tax outcome.</p>
          <p>My role is to help you stay compliant, reduce your tax liability legally, and make informed decisions with confidence.</p>
        </div>
      </div>
      <div class="split-col split-media">
        <img src="/assets/img/IMG_About-Ryan-2_1200x1500.webp" alt="Ryan Sims at work with a client" width="600" height="750" loading="lazy">
      </div>
    </div>
  </section>

  <!-- ======================= Expectations ======================= -->
  <section class="center-section center-section--closer">
    <div class="container">
      <h2 class="section-heading">What you can expect working with Proactive Accounting &amp; Tax</h2>
      <div class="rich-text">
        <p>My approach is proactive, communicative, and grounded in the reality of everyday business ownership. No judgment. No jargon. Just clear guidance and steady support.</p>
        <ul>
          <li>Clear explanations in plain English</li>
          <li>Thoughtful, proactive tax planning</li>
          <li>Integrated bookkeeping and tax strategy</li>
          <li>Honest answers and realistic expectations</li>
          <li>A long-term partnership &mdash; not a one-time transaction</li>
        </ul>
        <p><a href="/contact/">Schedule a consultation</a> and let&rsquo;s see if we&rsquo;re a good fit.</p>
      </div>
    </div>
  </section>
</BaseLayout>
